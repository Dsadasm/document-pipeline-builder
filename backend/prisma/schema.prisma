// NodeType model - predefined node types with their capabilities
model NodeType {
  name               String  @id @unique @db.VarChar(100)
  inputDataType      String  @db.VarChar(50)
  outputDataType     String  @db.VarChar(50)
  allowedCycleTarget String? @db.VarChar(100)
  nodes              Node[]
}
