### Variables
@baseUrl = http://localhost:3000
@apiPath = /api/pipelines

### Get all node types
GET http://localhost:3000/api/nodeType
Content-Type: application/json

### Create a valid pipeline
POST {{baseUrl}}{{apiPath}}
Content-Type: application/json

{
    "name": "Test Pipeline 1",
    "nodes": [
        {
            "id": "node-1",
            "type": "file_upload",
            "positionX": 100,
            "positionY": 100
        },
        {
            "id": "node-2",
            "type": "ocr",
            "positionX": 300,
            "positionY": 100
        },
        {
            "id": "node-3",
            "type": "email",
            "positionX": 500,
            "positionY": 100
        }
    ],
    "edges": [
        {
            "fromNodeId": "node-1",
            "toNodeId": "node-2"
        },
        {
            "fromNodeId": "node-2",
            "toNodeId": "node-3"
        }
    ]
}

### First, save the ID from creation (manually copy the ID from response)
POST {{baseUrl}}{{apiPath}}
Content-Type: application/json

{
    "name": "Pipeline To Update",
    "nodes": [
        {"id": "node-1a", "type": "file_uplod", "positionX": 0, "positionY": 0}
    ],
    "edges": []
}

### Update existing pipeline (replace {{updateId}} with actual ID)
POST {{baseUrl}}{{apiPath}}
Content-Type: application/json

{
    "id": "cmnw3wm28000106fl6a4zehnt",
    "name": "Updated Pipeline Name",
    "nodes": [
        {
            "id": "updated-node-1",
            "type": "file_upload",
            "positionX": 50,
            "positionY": 50
        },
        {
            "id": "updated-node-2",
            "type": "ocr",
            "positionX": 250,
            "positionY": 50
        }
    ],
    "edges": [
        {
            "fromNodeId": "updated-node-1",
            "toNodeId": "updated-node-2"
        }
    ]
}

### Get existing pipeline (replace {{pipelineId}})
GET {{baseUrl}}{{apiPath}}/cmnw3ypqn000406fl0nvs37im


### Get all pipelines (list view)
GET {{baseUrl}}{{apiPath}}

### Delete pipeline
DELETE {{baseUrl}}{{apiPath}}/cmnw3izvw0000p9fl923i8cb0

